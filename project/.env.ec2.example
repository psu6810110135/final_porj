# =============================
# Docker Compose for EC2
# Copy to .env.ec2 before deploy
# =============================

# Docker ports on EC2 host
FRONTEND_PORT=80
BACKEND_PORT=3000

# PostgreSQL container
POSTGRES_DB=thai_tours
POSTGRES_USER=thai_tours
POSTGRES_PASSWORD=replace-with-strong-db-password

# Backend runtime
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN
FRONTEND_URLS=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN
DATABASE_SSL=false
DB_SYNCHRONIZE=false
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=3d

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN/auth/google/callback

# Storage: local or s3
STORAGE_DRIVER=local
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_S3_KEY_PREFIX=thai-tour
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Admin seed on backend bootstrap
SEED_ADMIN_ON_BOOT=true
SEED_ADMIN_UPDATE_EXISTING=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_FULL_NAME=System Admin
SEED_ADMIN_PHONE=
SEED_ADMIN_IS_ACTIVE=true

# Frontend build arg (leave empty to use same-origin via nginx proxy)
VITE_API_URL=
